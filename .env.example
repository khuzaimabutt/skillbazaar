# =========================================
# SkillBazaar — Environment Variables
# Copy this file to .env.local and fill in real values
# =========================================

# ---- Supabase (https://supabase.com/dashboard) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Stripe TEST MODE ONLY (https://dashboard.stripe.com/test/apikeys) ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of admin emails (these accounts get is_admin=true on first login)
ADMIN_EMAILS=youremail@example.com

# Any random string — used to authenticate Vercel Cron requests
CRON_SECRET=replace-with-a-long-random-string

# ---- Node env (auto-set by Vercel in prod) ----
NODE_ENV=development
